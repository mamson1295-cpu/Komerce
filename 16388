<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Komerce — Gestion Commerciale</title>

    <!-- PWA -->
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#c8955a">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Komerce">
    <link rel="apple-touch-icon" href="data:image/svg+xml;base64,">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="sty.css">
</head>
<body>

    <!-- Écran sélection boutique -->
    <div id="shopScreen" class="shop-screen" style="display:none;">
        <div class="shop-screen-inner">
            <div class="shop-screen-brand">
                <div class="brand-icon" style="width:48px;height:48px;font-size:24px;">K</div>
                <h1 class="shop-screen-title">Komerce</h1>
                <p class="shop-screen-sub">Sélectionnez ou créez une boutique</p>
            </div>

            <div id="shopList" class="shop-list"></div>

            <div class="shop-create-form">
                <div class="field-row">
                    <div class="field" style="flex:1">
                        <input type="text" id="newShopName" class="field-input" placeholder="Nom de la boutique...">
                    </div>
                    <div class="field" style="flex:0">
                        <input type="color" id="newShopColor" class="shop-color-picker" value="#c8955a" title="Couleur">
                    </div>
                </div>
                <button id="createShopBtn" class="btn-primary" style="width:100%;">+ Créer la boutique</button>
            </div>
        </div>
    </div>

    <div class="app-shell" id="appShell">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">K</div>
                <div class="brand-text">
                    <span class="brand-name">Komerce</span>
                    <span class="brand-tagline">Gestion commerciale</span>
                </div>
            </div>

            <!-- Badge boutique active -->
            <div id="shopBadge" class="shop-badge" style="display:none;">
                <div class="shop-badge-dot"></div>
                <span id="shopBadgeName" class="shop-badge-name"></span>
                <button class="shop-badge-switch" id="switchShopBtn" title="Changer de boutique">⇄</button>
            </div>

            <nav class="sidebar-nav">
                <a class="nav-item active" data-tab="dashboard" href="#">
                    <span class="nav-icon">◈</span>
                    <span class="nav-label">Tableau de bord</span>
                </a>
                <a class="nav-item" data-tab="products" href="#">
                    <span class="nav-icon">⬡</span>
                    <span class="nav-label">Produits</span>
                </a>
                <a class="nav-item" data-tab="inventory" href="#">
                    <span class="nav-icon">⊞</span>
                    <span class="nav-label">Inventaire</span>
                </a>
                <a class="nav-item" data-tab="sales" href="#">
                    <span class="nav-icon">◉</span>
                    <span class="nav-label">Ventes</span>
                </a>
                <a class="nav-item" data-tab="expenses" href="#">
                    <span class="nav-icon">◍</span>
                    <span class="nav-label">Dépenses</span>
                </a>
                <a class="nav-item" data-tab="profit" href="#">
                    <span class="nav-icon">◆</span>
                    <span class="nav-label">Bénéfices</span>
                </a>
                <a class="nav-item" data-tab="history" href="#">
                    <span class="nav-icon">◷</span>
                    <span class="nav-label">Historique</span>
                </a>
                <a class="nav-item" data-tab="caisse" href="#">
                    <span class="nav-icon">◈</span>
                    <span class="nav-label">Caisse & Comptes</span>
                </a>
                <div class="nav-divider"></div>
                <a class="nav-item" data-tab="global" href="#">
                    <span class="nav-icon">⊕</span>
                    <span class="nav-label">Vue globale</span>
                </a>
                <a class="nav-item" data-tab="gerantscli" href="#">
                    <span class="nav-icon">👥</span>
                    <span class="nav-label">Gérants & Clients</span>
                </a>
                <a class="nav-item" data-tab="creditsbancaires" href="#">
                    <span class="nav-icon">🏦</span>
                    <span class="nav-label">Crédits bancaires</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <button id="themeToggleBtn" class="sidebar-action theme-toggle">
                    <span id="themeIcon">☀</span> <span id="themeLabel">Thème clair</span>
                </button>
                <button id="exportDataBtn" class="sidebar-action">
                    <span>↑</span> Exporter
                </button>
                <button id="importDataBtn" class="sidebar-action">
                    <span>↓</span> Importer
                </button>
                <input type="file" id="importFileInput" accept=".json" style="display:none;">
                <button id="printBtn" class="sidebar-action">
                    <span>⎙</span> Imprimer
                </button>
                <button id="resetAllBtn" class="sidebar-action danger">
                    <span>⊗</span> Réinitialiser
                </button>
            </div>
        </aside>

        <!-- Mobile header -->
        <header class="mobile-header">
            <button class="menu-toggle" id="menuToggle">☰</button>
            <span class="mobile-brand">Komerce</span>
            <span class="mobile-date" id="mobileDate"></span>
        </header>

        <!-- Main content -->
        <main class="main-content">

            <!-- DASHBOARD -->
            <section id="dashboard" class="tab-content active">
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Tableau de bord</h1>
                        <p class="page-subtitle" id="dashboardDate">Chargement...</p>
                    </div>
                    <div class="header-actions">
                        <button class="btn-ghost" onclick="App.goToInventory()">+ Inventaire du jour</button>
                    </div>
                </div>

                <!-- Alertes crédits bancaires -->
                <div id="cbAlertsBanner" class="cb-alerts-banner" style="display:none;"></div>

                <div class="kpi-grid">
                    <div class="kpi-card kpi-revenue">
                        <div class="kpi-label">Chiffre d'affaires total</div>
                        <div class="kpi-value" id="kpiRevenue">0 GNF</div>
                        <div class="kpi-sub" id="kpiRevenueSub">Toutes périodes</div>
                    </div>
                    <div class="kpi-card kpi-profit">
                        <div class="kpi-label">Bénéfice net</div>
                        <div class="kpi-value" id="kpiProfit">0 GNF</div>
                        <div class="kpi-sub" id="kpiProfitSub">Toutes périodes</div>
                    </div>
                    <div class="kpi-card kpi-margin">
                        <div class="kpi-label">Marge nette</div>
                        <div class="kpi-value" id="kpiMargin">0%</div>
                        <div class="kpi-sub">CA − Achats − Dépenses</div>
                    </div>
                    <div class="kpi-card kpi-stock">
                        <div class="kpi-label">Valeur du stock</div>
                        <div class="kpi-value" id="kpiStock">0 GNF</div>
                        <div class="kpi-sub">Prix de vente potentiel</div>
                    </div>
                    <div class="kpi-card kpi-liquidity">
                        <div class="kpi-label">Liquidités totales</div>
                        <div class="kpi-value" id="kpiLiquidity">0 GNF</div>
                        <div class="kpi-sub">Caisse + Mobile + Banque</div>
                    </div>
                </div>

                <div class="dashboard-grid">
                    <div class="card dash-card">
                        <div class="card-header">
                            <h2 class="card-title">Ventes récentes</h2>
                            <a data-tab="sales" href="#" class="card-link nav-item">Voir tout →</a>
                        </div>
                        <div id="recentSalesList" class="recent-list"></div>
                        <div id="emptyRecentSales" class="empty-mini" style="display:none">Aucune vente enregistrée</div>
                    </div>

                    <div class="card dash-card">
                        <div class="card-header">
                            <h2 class="card-title">Stocks critiques</h2>
                            <a data-tab="products" href="#" class="card-link nav-item">Gérer →</a>
                        </div>
                        <div id="lowStockList" class="recent-list"></div>
                        <div id="emptyLowStock" class="empty-mini" style="display:none">Tous les stocks sont OK ✓</div>
                    </div>

                    <div class="card dash-card full-width">
                        <div class="card-header">
                            <h2 class="card-title">Situation de la caisse</h2>
                            <a data-tab="caisse" href="#" class="card-link nav-item">Gérer →</a>
                        </div>
                        <div id="dashAccountsSummary" class="dash-accounts-summary"></div>
                    </div>

                    <div class="card dash-card full-width">
                        <div class="card-header">
                            <h2 class="card-title">Performance par produit</h2>
                        </div>
                        <div id="productPerformance" class="perf-bars"></div>
                        <div id="emptyPerformance" class="empty-mini" style="display:none">Enregistrez des ventes pour voir les performances</div>
                    </div>
                </div>
            </section>

            <!-- PRODUITS -->
            <section id="products" class="tab-content">
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Produits</h1>
                        <p class="page-subtitle">Gérez votre catalogue et vos stocks</p>
                    </div>
                </div>

                <div class="stock-banner">
                    <div class="stock-banner-item">
                        <span class="stock-banner-label">Valeur d'achat</span>
                        <span id="stockPurchaseValue" class="stock-banner-value">0 GNF</span>
                    </div>
                    <div class="stock-banner-divider"></div>
                    <div class="stock-banner-item">
                        <span class="stock-banner-label">Valeur de vente</span>
                        <span id="stockSaleValue" class="stock-banner-value highlight">0 GNF</span>
                    </div>
                    <div class="stock-banner-divider"></div>
                    <div class="stock-banner-item">
                        <span class="stock-banner-label">Marge potentielle</span>
                        <span id="stockMarginValue" class="stock-banner-value accent">0 GNF</span>
                    </div>
                </div>

                <div class="two-col-layout">
                    <div class="col-left">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Nouveau produit</h2>
                            </div>
                            <form id="productForm" class="form-stack">
                                <div class="field">
                                    <label class="field-label">Nom du produit</label>
                                    <input type="text" id="productName" class="field-input" required placeholder="Ex: Coca-Cola 33cl">
                                </div>
                                <div class="field-row">
                                    <div class="field">
                                        <label class="field-label">Prix de vente (GNF)</label>
                                        <input type="text" inputmode="decimal" id="productPrice" class="field-input" required placeholder="5 000">
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Prix d'achat (GNF)</label>
                                        <input type="text" inputmode="decimal" id="productCost" class="field-input" required placeholder="3 000">
                                    </div>
                                </div>
                                <div class="field">
                                    <label class="field-label">Stock initial</label>
                                    <input type="text" inputmode="decimal" id="productStock" class="field-input" required placeholder="50">
                                </div>
                                <div class="field">
                                    <label class="field-label">Seuil d'alerte stock</label>
                                    <input type="number" id="productAlert" class="field-input" min="0" placeholder="10 (optionnel)">
                                </div>
                                <button type="submit" class="btn-primary">Ajouter le produit</button>
                            </form>
                        </div>

                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Réapprovisionnement</h2>
                            </div>
                            <form id="restockForm" class="form-stack">
                                <div class="field">
                                    <label class="field-label">Produit</label>
                                    <select id="restockProduct" class="field-input field-select" required>
                                        <option value="">— Sélectionner un produit —</option>
                                    </select>
                                </div>
                                <div class="field-row">
                                    <div class="field">
                                        <label class="field-label">Quantité reçue</label>
                                        <input type="text" inputmode="decimal" id="restockQuantity" class="field-input" required placeholder="100">
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Prix d'achat (GNF)</label>
                                        <input type="text" inputmode="decimal" id="restockCost" class="field-input" required placeholder="3 000">
                                    </div>
                                </div>
                                <div class="field">
                                    <label class="field-label">Date de réception</label>
                                    <input type="date" id="restockDate" class="field-input" required>
                                </div>
                                <div class="restock-preview" id="restockPreview" style="display:none;">
                                    <div class="preview-row"><span>Stock actuel</span><span id="restockCurrentStock">—</span></div>
                                    <div class="preview-row"><span>Après réappro</span><span id="restockNewStock">—</span></div>
                                    <div class="preview-row accent"><span>Coût total</span><span id="restockTotalCost">—</span></div>
                                </div>
                                <button type="submit" class="btn-secondary">Réapprovisionner</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-right">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Catalogue</h2>
                                <span id="productCount" class="badge">0 produit</span>
                            </div>
                            <div class="field" style="margin-bottom: 16px;">
                                <input type="text" id="productSearch" class="field-input" placeholder="Rechercher un produit...">
                            </div>
                            <div id="productsList" class="products-list"></div>
                            <div id="emptyProducts" class="empty-state" style="display:none">
                                <div class="empty-icon">⬡</div>
                                <p>Aucun produit enregistré.</p>
                                <p class="empty-hint">Ajoutez votre premier produit avec le formulaire.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Edit Modal -->
                <div id="editModal" class="modal-overlay" style="display:none;">
                    <div class="modal">
                        <div class="modal-header">
                            <h2 class="modal-title">Modifier le produit</h2>
                            <button class="modal-close" onclick="App.closeEditModal()">✕</button>
                        </div>
                        <form id="editProductForm" class="form-stack">
                            <input type="hidden" id="editProductId">
                            <div class="field">
                                <label class="field-label">Nom du produit</label>
                                <input type="text" id="editProductName" class="field-input" required>
                            </div>
                            <div class="field-row">
                                <div class="field">
                                    <label class="field-label">Prix de vente (GNF)</label>
                                    <input type="text" inputmode="decimal" id="editProductPrice" class="field-input" required>
                                </div>
                                <div class="field">
                                    <label class="field-label">Prix d'achat (GNF)</label>
                                    <input type="text" inputmode="decimal" id="editProductCost" class="field-input" required>
                                </div>
                            </div>
                            <div class="field-row">
                                <div class="field">
                                    <label class="field-label">Stock initial</label>
                                    <input type="text" inputmode="decimal" id="editProductStock" class="field-input" required>
                                </div>
                                <div class="field">
                                    <label class="field-label">Seuil d'alerte</label>
                                    <input type="number" id="editProductAlert" class="field-input" min="0" placeholder="10">
                                </div>
                            </div>
                            <div class="field-note">⚠ Modifier le stock initial n'affecte pas les inventaires déjà enregistrés</div>
                            <div class="field-row">
                                <button type="submit" class="btn-primary">Enregistrer</button>
                                <button type="button" class="btn-ghost" onclick="App.closeEditModal()">Annuler</button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>

            <!-- INVENTAIRE -->
            <section id="inventory" class="tab-content">
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Inventaire</h1>
                        <p class="page-subtitle">Comptage journalier → Ventes déduites automatiquement</p>
                    </div>
                </div>

                <div class="info-banner">
                    <div class="info-formula">
                        <span class="formula-text">Ventes = Stock (hier soir) − Stock (compté ce soir)</span>
                    </div>
                    <p class="info-note">Comptez votre stock chaque soir. Les ventes sont calculées par différence avec le stock précédent.</p>
                </div>

                <div class="two-col-layout">
                    <div class="col-left">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Inventaire du jour</h2>
                                <div id="inventoryDateDisplay" class="date-badge"></div>
                            </div>
                            <form id="inventoryForm" class="form-stack">
                                <div id="inventoryInputs" class="inventory-grid"></div>
                                <div id="emptyInventory" class="empty-state" style="display:none">
                                    <div class="empty-icon">⊞</div>
                                    <p>Ajoutez d'abord des produits dans l'onglet "Produits".</p>
                                </div>
                                <div id="invLiveTotal" class="inv-live-total" style="display:none;">
                                    <div class="inv-live-item">
                                        <span class="inv-live-label">CA du jour</span>
                                        <span id="invTotalCA" class="inv-live-val pos">0 GNF</span>
                                    </div>
                                    <div class="inv-live-item">
                                        <span class="inv-live-label">Marge du jour</span>
                                        <span id="invTotalMarge" class="inv-live-val accent">0 GNF</span>
                                    </div>
                                </div>
                                <button type="submit" class="btn-primary" id="inventorySubmitBtn" style="display:none;">Enregistrer l'inventaire</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-right">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Corriger un inventaire passé</h2>
                            </div>
                            <div class="field" style="margin-bottom: 16px;">
                                <label class="field-label">Sélectionner une date</label>
                                <input type="date" id="historyDatePicker" class="field-input">
                            </div>
                            <div id="historyInventoryEdit" class="inventory-grid" style="display:none;"></div>
                            <button id="updateHistoryBtn" class="btn-secondary" style="display:none; margin-top:12px;">
                                Mettre à jour et recalculer
                            </button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- VENTES -->
            <section id="sales" class="tab-content">
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Ventes</h1>
                        <p class="page-subtitle">Historique calculé à partir des inventaires</p>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Ventes du jour</h2>
                        <div id="todaySalesTotal" class="kpi-inline"></div>
                    </div>
                    <div id="todaySales" class="sales-day-grid"></div>
                    <div id="emptyTodaySales" class="empty-state" style="display:none">
                        <div class="empty-icon">◉</div>
                        <p>Aucun inventaire enregistré aujourd'hui.</p>
                        <p class="empty-hint">Allez dans l'onglet <a data-tab="inventory" href="#" class="nav-item inline-link">Inventaire</a> pour enregistrer le stock du soir.</p>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Toutes les ventes</h2>
                        <div class="table-filters">
                            <input type="text" id="salesSearch" class="field-input mini" placeholder="Filtrer...">
                        </div>
                    </div>
                    <div class="table-wrap">
                        <table class="data-table" id="salesByProductTable">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Produit</th>
                                    <th>Stock veille</th>
                                    <th>Stock compté</th>
                                    <th>Qté vendue</th>
                                    <th>Sorties</th>
                                    <th>CA</th>
                                    <th>Marge</th>
                                </tr>
                            </thead>
                            <tbody id="salesByProductBody"></tbody>
                        </table>
                    </div>
                    <div id="emptySalesByProduct" class="empty-state" style="display:none">
                        <p>Aucune vente calculée.</p>
                    </div>
                </div>
            </section>

            <!-- DÉPENSES -->
            <section id="expenses" class="tab-content">
                <div class="page-header">
                    <div>
                        <h1 class="page-title">Dépenses</h1>
                        <p class="page-subtitle">Charges fixes et variables</p>
                    </div>
                </div>

                <div class="two-col-layout">
                    <div class="col-left">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Nouvelle dépense</h2>
                            </div>
                            <form id="expenseForm" class="form-stack">
                                <div class="field-row">
                                    <div class="field">
                                        <label class="field-label">Date</label>
                                        <input type="date" id="expenseDate" class="field-input" required>
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Catégorie</label>
                                        <select id="expenseCategory" class="field-input field-select" required>
                                            <option value="">— Catégorie —</option>
                                            <option value="loyer">🏠 Loyer</option>
                                            <option value="electricite">⚡ Électricité / Eau / Gaz</option>
                                            <option value="fournitures">📎 Fournitures</option>
                                            <option value="marketing">📢 Marketing / Pub</option>
                                            <option value="salaires">👥 Salaires</option>
                                            <option value="maintenance">🔧 Maintenance</option>
                                            <option value="transport">🚚 Transport</option>
                                            <option value="impots">📋 Impôts / Taxes</option>
                                            <option value="autre">❓ Autre</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="field">
                                    <label class="field-label">Description</label>
                                    <input type="text" id="expenseDescription" class="field-input" required placeholder="Ex: Loyer avril 2026">
                                </div>
                                <div class="field-row">
                                    <div class="field">
                                        <label class="field-label">Montant (GNF)</label>
                                        <input type="text" inputmode="decimal" id="expenseAmount" class="field-input" required placeholder="500 000">
                                    </div>
                                    <div class="field">
                                        <label class="field-label">Récurrence</label>
                                        <select id="expenseRecurring" class="field-input field-select">
                                            <option value="once">Une fois</option>
                                            <option value="daily">Quotidienne</option>
                                            <option value="weekly">Hebdomadaire</option>
                                            <option value="monthly">Mensuelle</option>
                                        </select>
                                    </div>
                                </div>
                                <button type="submit" class="btn-primary">Ajouter la dépense</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-right">
                        <div class="card">
                            <div class="card-header">
                                <h2 class="card-title">Dépenses par catégorie</h2>
                            </div>
                            <div id="expensesByCategory" class="category-chart"></div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h2 class="card-title">Toutes les dépenses</h2>
                        <div id="expensesTotal" class="kpi-inline negative"></div>
                    </div>
                    <div class="table-wrap">
                        <table class="data-table" id="expensesTable">
                            <thead>
                                <tr>
