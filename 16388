            <form id="creditForm" class="form-stack">
                <input type="hidden" id="creditClientId">
                <div class="field">
                    <label class="field-label">Date</label>
                    <input type="date" id="creditDate" class="field-input" required>
                </div>
                <div class="field">
                    <label class="field-label">Description (produits achetés)</label>
                    <input type="text" id="creditDescription" class="field-input" required placeholder="Ex: 2 sacs de riz, 1 bidon huile">
                </div>
                <div class="field">
                    <label class="field-label">Montant total (GNF)</label>
                    <input type="text" inputmode="decimal" id="creditMontant" class="field-input" required placeholder="50 000">
                </div>
                <button type="submit" class="btn-primary">Enregistrer le crédit</button>
            </form>
        </div>
    </div>

    <!-- Modal remboursement -->
    <div id="rembModal" class="modal-overlay" style="display:none;">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title" id="rembModalTitle">Remboursement</h2>
                <button class="modal-close" onclick="App.closeRembModal()">✕</button>
            </div>
            <form id="rembForm" class="form-stack">
                <div class="field-row">
                    <div class="field">
                        <label class="field-label">Montant (GNF)</label>
                        <input type="text" inputmode="decimal" id="rembMontant" class="field-input" required placeholder="10 000">
                    </div>
                    <div class="field">
                        <label class="field-label">Date</label>
                        <input type="date" id="rembDate" class="field-input" required>
                    </div>
                </div>
                <div class="field">
                    <label class="field-label">Mode de remboursement</label>
                    <select id="rembType" class="field-input field-select">
                        <option value="espèces">💵 Espèces</option>
                        <option id="rembTypeMobile" value="mobile">📱 Mobile Money</option>
                        <option value="salaire">👥 Retenue sur salaire</option>
                    </select>
                </div>
                <div class="field">
                    <label class="field-label">Note (optionnel)</label>
                    <input type="text" id="rembNote" class="field-input" placeholder="Ex: Paiement partiel...">
                </div>
                <button type="submit" class="btn-primary">Enregistrer le remboursement</button>
            </form>
        </div>
    </div>
    <div id="movementModal" class="modal-overlay" style="display:none;">
        <div class="modal">
            <div class="modal-header">
                <h2 class="modal-title" id="movModalTitle">Mouvement</h2>
                <button class="modal-close" onclick="App.closeMovementModal()">✕</button>
            </div>
            <form id="movModalForm" class="form-stack">
                <input type="hidden" id="movModalType">
                <input type="hidden" id="movModalAccount">
                <div class="field-row">
                    <div class="field">
                        <label class="field-label">Montant (GNF)</label>
                        <input type="text" inputmode="decimal" id="movModalAmount" class="field-input" required placeholder="50 000">
                    </div>
                    <div class="field">
                        <label class="field-label">Date</label>
                        <input type="date" id="movModalDate" class="field-input" required>
                    </div>
                </div>
                <div class="field">
                    <label class="field-label">Libellé</label>
                    <input type="text" id="movModalLabel" class="field-input" required placeholder="Ex: Achat fournisseur">
                </div>
                <button type="submit" class="btn-primary">Enregistrer</button>
            </form>
        </div>
    </div>

    <!-- Modal impression -->
    <div id="printModal" class="modal-overlay" style="display:none;">
        <div class="modal" style="max-width:520px;">
            <div class="modal-header">
                <h2 class="modal-title">⎙ Imprimer un rapport</h2>
                <button class="modal-close" onclick="App.closePrintModal()">✕</button>
            </div>
            <div class="form-stack">
                <div class="field">
                    <label class="field-label">Rapport à imprimer</label>
                    <select id="printReportType" class="field-input field-select">
                        <option value="dashboard">Tableau de bord (résumé global)</option>
                        <option value="sales">Ventes détaillées</option>
                        <option value="expenses">Dépenses</option>
                        <option value="profit">Rapport bénéfices</option>
                        <option value="inventory">Historique inventaires</option>
                        <option value="caisse">Mouvements de caisse</option>
                    </select>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="field-label">Du (optionnel)</label>
                        <input type="date" id="printStartDate" class="field-input">
                    </div>
                    <div class="field">
                        <label class="field-label">Au (optionnel)</label>
                        <input type="date" id="printEndDate" class="field-input">
                    </div>
                </div>
                <button class="btn-primary" onclick="App.doPrint()">⎙ Générer et imprimer</button>
                <button class="btn-ghost" onclick="App.closePrintModal()">Annuler</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>
    <script src="ap.js"></script>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('./sw.js')
                    .then(reg => console.log('SW enregistré :', reg.scope))
                    .catch(err => console.warn('SW non enregistré :', err));
            });
        }
    </script>
</body>
</html>
